{
  "$schema": "https://docs.claude.com/schemas/settings.json",
  
  "permission": {
    "skill": {
      "*": "allow"
    },
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "read": {
      "*": "allow",
      ".opencode/**": "allow"
    },
    "write": {
      "*": "ask",
      ".opencode/team/**": "allow"
    }
  },

  "auto_invoke_skills": [
    "opencode-bridge"
  ],

  "statusline": {
    "enabled": true,
    "format": "{PROJECT_NAME} | {BRANCH} | {AGENT_STATUS}"
  },

  "hooks": {
    "pre_task": [],
    "post_task": [],
    "pre_commit": [],
    "post_commit": []
  },

  "experimental": {
    "multi_agent": true,
    "parallel_tasks": true
  }
}
