{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ]
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "read": {
      "*": "allow",
      ".opencode/**": "allow"
    },
    "write": {
      "*": "ask",
      ".opencode/team/**": "allow"
    }
  },
  "auto_invoke_skills": [
    "opencode-bridge"
  ],
  "statusline": {
    "enabled": true,
    "format": "{PROJECT_NAME} | {BRANCH} | {AGENT_STATUS}"
  },
  "experimental": {
    "multi_agent": true,
    "parallel_tasks": true
  }
}
